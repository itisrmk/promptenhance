#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$(command -v "$0")")"
PACKAGE_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

echo_info() { printf "[promptenhance] %s\n" "$*"; }
echo_warn() { printf "[promptenhance] WARNING: %s\n" "$*"; }
echo_err() { printf "[promptenhance] ERROR: %s\n" "$*" >&2; }

usage() {
  cat <<'USAGE'
Usage:
  promptenhance init [PATH] [--force]
  promptenhance verify [PATH]
  promptenhance status [--tail N]
  promptenhance help

Commands:
  init    Initialize promptenhance in PATH (default: current directory).
         Works in empty directories by bootstrapping required plugin files.
         PATH defaults to current directory and can be any target project folder.
  verify  Run hook verification (same as make verify). PATH defaults to current dir.
  status  Show recent local promptenhance hook run log entries.
  help    Show this help.
USAGE
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

copy_with_policy() {
  local src="$1"
  local dst="$2"
  local force="$3"  # 1 = overwrite, 0 = keep existing

  python3 - "$src" "$dst" "$force" <<'PY'
from pathlib import Path
import shutil
import sys

src = Path(sys.argv[1])
dst = Path(sys.argv[2])
force = sys.argv[3] == "1"

if not src.exists():
    raise SystemExit(f"expected source missing: {src}")


def sync_tree(current_src: Path, current_dst: Path) -> None:
    if current_src.is_dir():
        current_dst.mkdir(parents=True, exist_ok=True)
        for child in sorted(current_src.iterdir()):
            sync_tree(child, current_dst / child.name)
    else:
        if current_dst.exists() and not force:
            return
        current_dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(current_src, current_dst)

sync_tree(src, dst)
PY
}

copy_scaffold() {
  local target="$1"
  local force="$2"

  mkdir -p "$target"

  copy_with_policy "$PACKAGE_ROOT/plugin.json" "$target/plugin.json" "$force"
  copy_with_policy "$PACKAGE_ROOT/.claude-plugin" "$target/.claude-plugin" "$force"

  if [[ -d "$PACKAGE_ROOT/commands" ]]; then
    copy_with_policy "$PACKAGE_ROOT/commands" "$target/commands" "$force"
  fi
  if [[ -d "$PACKAGE_ROOT/skills" ]]; then
    copy_with_policy "$PACKAGE_ROOT/skills" "$target/skills" "$force"
  fi
}

attempt_local_install() {
  local target="$1"

  if ! has_cmd claude; then
    echo_warn "Claude CLI not found. Scaffold prepared; install/setup Claude CLI to activate hooks."
    return 0
  fi

  local out
  if out=$(cd "$target" && claude plugin install . --scope project 2>&1); then
    echo_info "$out"
    echo_info "Project plugin installation command completed."
    return 0
  fi

  if echo "$out" | grep -qi "not found in any configured marketplace"; then
    echo_warn "This Claude CLI does not support local plugin install from path."
    echo_warn "Scaffold is in place and ready for this project."
    return 0
  fi

  echo_err "claude plugin install failed. output:"
  echo "$out" >&2
  return 1
}

cmd_init() {
  local target="${PWD}"
  local force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force)
        force=1
        shift
        ;;
      --help|-h)
        usage
        return 0
        ;;
      *)
        target="$1"
        shift
        ;;
    esac
  done

  if [[ ! -d "$target" ]]; then
    mkdir -p "$target"
  fi

  echo_info "Preparing promptenhance scaffold in: $target"
  copy_scaffold "$target" "$force"

  local entry_file="$target/.claude-plugin/hooks/user-prompt-submit/enhance.py"
  if [[ ! -f "$entry_file" ]]; then
    echo_err "Scaffold copy incomplete. Missing expected file: $entry_file"
    return 1
  fi

  attempt_local_install "$target" || true

  echo_info "promptenhance is ready in: $target"
  echo_info "Use this command in the same folder whenever needed:"
  echo_info "  claude plugin list" 
  echo_info "Then start a Claude session and prompt normally."
}

cmd_status() {
  local target="${PWD}"
  local tail_n=20

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tail)
        tail_n="$2"
        shift 2
        ;;
      --help|-h)
        echo "Usage: promptenhance status [--tail N]"
        return 0
        ;;
      *)
        if [[ -d "$1" ]]; then
          target="$1"
          shift
        else
          echo_warn "ignoring unexpected arg: $1"
          shift
        fi
        ;;
    esac
  done

  local log_path
  log_path="$target/.claude/promptenhance.log"
  if [[ ! -f "$target/.claude/promptenhance.json" ]]; then
    log_path="$HOME/.claude/promptenhance.log"
  fi
  if [[ ! -f "$log_path" ]]; then
    echo_warn "No promptenhance log file found at: $log_path"
    return 0
  fi

  echo_info "Recent promptenhance events (tail -n $tail_n):"
  tail -n "$tail_n" "$log_path"
}


cmd_verify() {
  local target="${1:-$PWD}"
  if [[ -f "$target/Makefile" ]] && has_cmd make; then
    (cd "$target" && make verify)
    return $?
  fi
  bash "$PACKAGE_ROOT/scripts/verify_promptenhance.sh"
}

case "${1-}" in
  init)
    shift
    cmd_init "$@"
    ;;
  verify)
    shift
    cmd_verify "$@"
    ;;
  status)
    shift
    cmd_status "$@"
    ;;
  help|--help|-h)
    usage
    ;;
  "")
    usage
    ;;
  *)
    echo_err "unknown command: ${1}"
    usage
    exit 1
    ;;
esac
