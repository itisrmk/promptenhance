#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$(command -v "$0")")"
PACKAGE_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

echo_info() { printf "[promptenhance] %s\n" "$*"; }
echo_warn() { printf "[promptenhance] WARNING: %s\n" "$*"; }
echo_err() { printf "[promptenhance] ERROR: %s\n" "$*" >&2; }

usage() {
  cat <<'USAGE'
Usage:
  promptenhance init [PATH] [--force]
  promptenhance verify [PATH]
  promptenhance status [PATH] [--tail N]
  promptenhance help

Commands:
  init    Initialize promptenhance in PATH (default: current directory).
         Works in empty directories by bootstrapping required plugin files.
         PATH defaults to current directory and can be any target project folder.
  verify  Run hook verification (same as make verify). PATH defaults to current dir.
  status  Show recent local promptenhance status and config for this project.
  help    Show this help.
USAGE
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

copy_with_policy() {
  local src="$1"
  local dst="$2"
  local force="$3"  # 1 = overwrite, 0 = keep existing

  python3 - "$src" "$dst" "$force" <<'PY'
from pathlib import Path
import shutil
import sys

src = Path(sys.argv[1])
dst = Path(sys.argv[2])
force = sys.argv[3] == "1"

if not src.exists():
    raise SystemExit(f"expected source missing: {src}")


def sync_tree(current_src: Path, current_dst: Path) -> None:
    if current_src.is_dir():
        current_dst.mkdir(parents=True, exist_ok=True)
        for child in sorted(current_src.iterdir()):
            sync_tree(child, current_dst / child.name)
    else:
        if current_dst.exists() and not force:
            return
        current_dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(current_src, current_dst)

sync_tree(src, dst)
PY
}

copy_scaffold() {
  local target="$1"
  local force="$2"

  mkdir -p "$target"

  copy_with_policy "$PACKAGE_ROOT/plugin.json" "$target/plugin.json" "$force"
  copy_with_policy "$PACKAGE_ROOT/.claude-plugin" "$target/.claude-plugin" "$force"

  if [[ -d "$PACKAGE_ROOT/commands" ]]; then
    copy_with_policy "$PACKAGE_ROOT/commands" "$target/commands" "$force"
  fi
  if [[ -d "$PACKAGE_ROOT/skills" ]]; then
    copy_with_policy "$PACKAGE_ROOT/skills" "$target/skills" "$force"
  fi
}

attempt_local_install() {
  local target="$1"

  if ! has_cmd claude; then
    echo_warn "Claude CLI not found. Scaffold prepared; install/setup Claude CLI to activate hooks."
    return 0
  fi

  local out
  if out=$(cd "$target" && claude plugin install . --scope project 2>&1); then
    echo_info "$out"
    echo_info "Project plugin installation command completed."
    return 0
  fi

  if echo "$out" | grep -qi "not found in any configured marketplace"; then
    echo_warn "This Claude CLI does not support local plugin install from a local path."
    echo_warn "Scaffold is in place and ready for this project."
    echo_warn "Note: the plugin may not appear under ~/.claude/plugins on some CLI versions, while still working locally."
    echo_warn ""
    echo_warn "Verify setup with these commands in the project folder:"
    echo_warn "  1) promptenhance status   # check plugin.json + hook file presence"
    echo_warn "  2) promptenhance verify   # validate hook JSON contract locally"
    echo_warn "  3) printf '{\"prompt\":\"fix it\"}' | python3 .claude-plugin/hooks/user-prompt-submit/enhance.py"
    return 0
  fi

  echo_err "claude plugin install failed. output:"
  echo "$out" >&2
  return 1
}

cmd_init() {
  local target="${PWD}"
  local force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force)
        force=1
        shift
        ;;
      --help|-h)
        usage
        return 0
        ;;
      *)
        target="$1"
        shift
        ;;
    esac
  done

  if [[ ! -d "$target" ]]; then
    mkdir -p "$target"
  fi

  echo_info "Preparing promptenhance scaffold in: $target"
  copy_scaffold "$target" "$force"

  local entry_file="$target/.claude-plugin/hooks/user-prompt-submit/enhance.py"
  if [[ ! -f "$entry_file" ]]; then
    echo_err "Scaffold copy incomplete. Missing expected file: $entry_file"
    return 1
  fi

  attempt_local_install "$target" || true

  echo_info "promptenhance is ready in: $target"
  echo_info "Use these commands in the same folder:"
  echo_info "  promptenhance status    # verify plugin.json + hook presence and config"
  echo_info "  promptenhance verify    # validate hook execution path"
  echo_info "Then start a Claude session and prompt normally."
}

cmd_status() {
  local target="${PWD}"
  local tail_n=20

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tail)
        tail_n="$2"
        shift 2
        ;;
      --help|-h)
        echo "Usage: promptenhance status [PATH] [--tail N]"
        return 0
        ;;
      *)
        if [[ -d "$1" ]]; then
          target="$1"
          shift
        else
          echo_warn "ignoring unexpected arg: $1"
          shift
        fi
        ;;
    esac
  done

  echo_info "PromptEnhance status for: $target"

  local plugin_file="$target/plugin.json"
  local hook_file="$target/.claude-plugin/hooks/user-prompt-submit/enhance.py"

  if [[ -f "$plugin_file" ]]; then
    echo_info "plugin.json: present"
  else
    echo_warn "plugin.json: missing"
  fi

  if [[ -f "$hook_file" ]]; then
    echo_info "hook: present ($hook_file)"
  else
    echo_warn "hook: missing ($hook_file)"
  fi

  local cfg_text
  local cfg_lines
  cfg_text="$(python3 - "$HOME/.claude/promptenhance.json" "$target/.claude/promptenhance.json" <<'PY'
import json
from pathlib import Path
import sys


def read_cfg(path):
    try:
        p = Path(path)
        if p.exists() and p.is_file():
            data = json.loads(p.read_text(encoding='utf-8', errors='ignore'))
            if isinstance(data, dict):
                return data
    except Exception:
        pass
    return {}


def to_bool(value, default=False):
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return bool(value)
    if isinstance(value, str):
        return value.strip().lower() not in {"0", "false", "no", "off"}
    return default

home_cfg = read_cfg(sys.argv[1])
proj_cfg = read_cfg(sys.argv[2])
cfg = {
    "promptenhance_show_marker": True,
    "promptenhance_show_diff": False,
    "log_path": str(Path.home() / ".claude" / "promptenhance.log"),
}
cfg.update(home_cfg)
cfg.update(proj_cfg)

print('true' if to_bool(cfg.get("promptenhance_show_marker", True), True) else 'false')
print('true' if to_bool(cfg.get("promptenhance_show_diff", False), False) else 'false')
print(cfg.get('log_path', str(Path.home() / '.claude' / 'promptenhance.log')))
PY
)"

  IFS=$'\n' read -r -a cfg_lines <<< "$cfg_text"

  local marker=${cfg_lines[0]:-true}
  local diff=${cfg_lines[1]:-false}
  local log_path=${cfg_lines[2]:-$HOME/.claude/promptenhance.log}

  echo_info "promptenhance_show_marker: ${marker}"
  echo_info "promptenhance_show_diff: ${diff}"
  echo_info "Resolved log_path: ${log_path}"

  if [[ ! -f "$log_path" ]]; then
    echo_warn "No promptenhance log file found at: $log_path"
    return 0
  fi

  local cli_plugin_path="$HOME/.claude/plugins"

  echo_info "Recent promptenhance events (tail -n $tail_n):"
  tail -n "$tail_n" "$log_path"

  echo_info "Note: If plugin is local and this Claude CLI does not support project-scoped install, it may not show in $cli_plugin_path."
}

cmd_verify() {
  local target="${1:-$PWD}"
  if [[ -f "$target/Makefile" ]] && has_cmd make; then
    (cd "$target" && make verify)
    return $?
  fi
  bash "$PACKAGE_ROOT/scripts/verify_promptenhance.sh"
}

case "${1-}" in
  init)
    shift
    cmd_init "$@"
    ;;
  verify)
    shift
    cmd_verify "$@"
    ;;
  status)
    shift
    cmd_status "$@"
    ;;
  help|--help|-h)
    usage
    ;;
  "")
    usage
    ;;
  *)
    echo_err "unknown command: ${1}"
    usage
    exit 1
    ;;
esac
